OPENAI_API_KEY="sk-placeholder"
DATABASE_URL="file:./dev.db"
ARTIFACT_STORAGE_ROOT="./public/artifacts"
NEXT_PUBLIC_APP_NAME="OpenAI-Native Diagram and Image Editor"
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
IMAGE_GENERATION_PROVIDER="openai"

# Optional Gemini image generation and mask-guided image editing.
# Nano Banana 2 model. Uncomment the provider lines only when you want Gemini.
GOOGLE_API_KEY="AIza-placeholder"
GOOGLE_IMAGE_MODEL="gemini-3.1-flash-image-preview"
# IMAGE_GENERATION_PROVIDER="gemini"
# DIAGRAM_IMAGE_PROVIDER="gemini"

# Uses Sharp to rasterize rendered SVG verification snapshots to PNG when available.
DIAGRAM_VERIFICATION_ENABLED="true"

# Docker defaults used by docker-compose.yml:
# DATABASE_URL="file:/app/data/dev.db"
# ARTIFACT_STORAGE_ROOT="/app/public/artifacts"
